# Supabase
# The base URL for your Supabase project
SUPABASE_URL=YOUR_SUPABASE_URL_PLACEHOLDER
# The anon key for public client-side access
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_PLACEHOLDER
# The service role key for admin-level backend operations (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_PLACEHOLDER

# Format: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=YOUR_DATABASE_URL_PLACEHOLDER

# Restaurant Providers
# Primary provider for fetching restaurant data
RESTAURANT_PROVIDER_PRIMARY=osm
# Fallback provider if primary fails
RESTAURANT_PROVIDER_FALLBACK=geoapify
# Last resort provider
RESTAURANT_PROVIDER_LAST_RESORT=foursquare

# API endpoints and keys for providers
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
GEOAPIFY_API_KEY=YOUR_GEOAPIFY_API_KEY_PLACEHOLDER
FOURSQUARE_API_KEY=YOUR_FOURSQUARE_API_KEY_PLACEHOLDER

# Environment
# Deployment environment (e.g., development, staging, production)
ENVIRONMENT=development
# Logging detail level (e.g., debug, info, warn, error)
LOG_LEVEL=info

# App
# The application name
APP_NAME=Cravit
# The base URL of the frontend application
APP_URL=http://localhost:3000
